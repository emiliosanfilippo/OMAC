    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.omac.org/#Allusion -->

    <owl:Class rdf:about="http://www.omac.org/#Allusion">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#SimilarityRelationship"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Analyst -->

    <owl:Class rdf:about="http://www.omac.org/#Analyst">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#Person"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Arrangement -->

    <owl:Class rdf:about="http://www.omac.org/#Arrangement">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#SimilarityRelationship"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Claim -->

    <owl:Class rdf:about="http://www.omac.org/#Claim"/>
    


    <!-- http://www.omac.org/#Collage -->

    <owl:Class rdf:about="http://www.omac.org/#Collage">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#SimilarityRelationship"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#ComplexWork -->

    <owl:Class rdf:about="http://www.omac.org/#ComplexWork">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#Work"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Composer -->

    <owl:Class rdf:about="http://www.omac.org/#Composer">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#Person"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Contrafact -->

    <owl:Class rdf:about="http://www.omac.org/#Contrafact">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#SimilarityRelationship"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Elaboration -->

    <owl:Class rdf:about="http://www.omac.org/#Elaboration">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#Transformation"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Expression -->

    <owl:Class rdf:about="http://www.omac.org/#Expression">
        <rdfs:comment>REMINDER: check hasFragment and hasComponent</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.omac.org/#ExpressionFragment -->

    <owl:Class rdf:about="http://www.omac.org/#ExpressionFragment">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.omac.org/#Expression"/>
                    <owl:Class>
                        <owl:complementOf>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.omac.org/#hasComponent"/>
                                <owl:someValuesFrom rdf:resource="http://www.omac.org/#Expression"/>
                            </owl:Restriction>
                        </owl:complementOf>
                    </owl:Class>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.omac.org/#hasFragment"/>
                        <owl:allValuesFrom rdf:resource="http://www.omac.org/#ExpressionFragment"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.omac.org/#satisfiesUnityCriteria"/>
                        <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:disjointWith rdf:resource="http://www.omac.org/#SelfContainedExpression"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Homage -->

    <owl:Class rdf:about="http://www.omac.org/#Homage">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#SimilarityRelationship"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Imitation -->

    <owl:Class rdf:about="http://www.omac.org/#Imitation">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#SimilarityRelationship"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#IndividualWork -->

    <owl:Class rdf:about="http://www.omac.org/#IndividualWork">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#Work"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#MechanicalTransformation -->

    <owl:Class rdf:about="http://www.omac.org/#MechanicalTransformation">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#Transformation"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#MusicalWork -->

    <owl:Class rdf:about="http://www.omac.org/#MusicalWork">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#Work"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#NewCombination -->

    <owl:Class rdf:about="http://www.omac.org/#NewCombination">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#Transformation"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#NonMechanicalTransformation -->

    <owl:Class rdf:about="http://www.omac.org/#NonMechanicalTransformation">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#Transformation"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Omission -->

    <owl:Class rdf:about="http://www.omac.org/#Omission">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#SimilarityRelationship"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Parody -->

    <owl:Class rdf:about="http://www.omac.org/#Parody">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#SimilarityRelationship"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Pattern -->

    <owl:Class rdf:about="http://www.omac.org/#Pattern">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#Expression"/>
        <rdfs:comment xml:lang="en">Small building blocks that come in conventional schemas involving pairs of voices</rdfs:comment>
        <rdfs:comment xml:lang="en">TO DO: is this a fragment or a self-contained expression?</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.omac.org/#Person -->

    <owl:Class rdf:about="http://www.omac.org/#Person"/>
    


    <!-- http://www.omac.org/#Plagiat -->

    <owl:Class rdf:about="http://www.omac.org/#Plagiat">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#SimilarityRelationship"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Prolongation -->

    <owl:Class rdf:about="http://www.omac.org/#Prolongation">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#Transformation"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Quotation -->

    <owl:Class rdf:about="http://www.omac.org/#Quotation">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#SimilarityRelationship"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Rendition -->

    <owl:Class rdf:about="http://www.omac.org/#Rendition">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#SimilarityRelationship"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#SelfContainedExpression -->

    <owl:Class rdf:about="http://www.omac.org/#SelfContainedExpression">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.omac.org/#Expression"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.omac.org/#realises"/>
                        <owl:someValuesFrom rdf:resource="http://www.omac.org/#Work"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.omac.org/#hasComponent"/>
                        <owl:allValuesFrom rdf:resource="http://www.omac.org/#SelfContainedExpression"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.omac.org/#hasFragment"/>
                        <owl:allValuesFrom rdf:resource="http://www.omac.org/#ExpressionFragment"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.omac.org/#satisfiesUnityCriteria"/>
                        <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://www.omac.org/#SelfContainedMusicalExpression -->

    <owl:Class rdf:about="http://www.omac.org/#SelfContainedMusicalExpression">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.omac.org/#SelfContainedExpression"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.omac.org/#realises"/>
                        <owl:someValuesFrom rdf:resource="http://www.omac.org/#MusicalWork"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://www.omac.org/#SimilarityRelationship -->

    <owl:Class rdf:about="http://www.omac.org/#SimilarityRelationship">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.omac.org/#hasDerivative"/>
                <owl:someValuesFrom rdf:resource="http://www.omac.org/#MusicalWork"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.omac.org/#hasModel"/>
                <owl:someValuesFrom rdf:resource="http://www.omac.org/#MusicalWork"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.omac.org/#Simplification -->

    <owl:Class rdf:about="http://www.omac.org/#Simplification">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#Transformation"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Transcription -->

    <owl:Class rdf:about="http://www.omac.org/#Transcription">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#SimilarityRelationship"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Transformation -->

    <owl:Class rdf:about="http://www.omac.org/#Transformation">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#SimilarityRelationship"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Truncation -->

    <owl:Class rdf:about="http://www.omac.org/#Truncation">
        <rdfs:subClassOf rdf:resource="http://www.omac.org/#Transformation"/>
    </owl:Class>
    


    <!-- http://www.omac.org/#Work -->

    <owl:Class rdf:about="http://www.omac.org/#Work">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.omac.org/#ComplexWork"/>
                    <rdf:Description rdf:about="http://www.omac.org/#IndividualWork"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">CHECK complex and invidual work, among others, in FRBRoo</rdfs:comment>
    </owl:Class>
    


