    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.omac.org/#Antoine_de_Fevin -->

    <owl:NamedIndividual rdf:about="http://www.omac.org/#Antoine_de_Fevin">
        <rdf:type rdf:resource="http://www.omac.org/#Composer"/>
    </owl:NamedIndividual>
    


    <!-- http://www.omac.org/#De_Fevin_Missa_Ave_Maria -->

    <owl:NamedIndividual rdf:about="http://www.omac.org/#De_Fevin_Missa_Ave_Maria">
        <rdf:type rdf:resource="http://www.omac.org/#MusicalWork"/>
        <composedBy rdf:resource="http://www.omac.org/#Antoine_de_Fevin"/>
    </owl:NamedIndividual>
    


    <!-- http://www.omac.org/#De_Pres_Ave_Maria -->

    <owl:NamedIndividual rdf:about="http://www.omac.org/#De_Pres_Ave_Maria">
        <rdf:type rdf:resource="http://www.omac.org/#MusicalWork"/>
        <composedBy rdf:resource="http://www.omac.org/#Josquin_des_Prez"/>
    </owl:NamedIndividual>
    


    <!-- http://www.omac.org/#Josquin_des_Prez -->

    <owl:NamedIndividual rdf:about="http://www.omac.org/#Josquin_des_Prez">
        <rdf:type rdf:resource="http://www.omac.org/#Composer"/>
    </owl:NamedIndividual>
    


    <!-- http://www.omac.org/#Peter_Schubert -->

    <owl:NamedIndividual rdf:about="http://www.omac.org/#Peter_Schubert">
        <rdf:type rdf:resource="http://www.omac.org/#Analyst"/>
    </owl:NamedIndividual>
    


    <!-- http://www.omac.org/#Schubert_claim_id23 -->

    <owl:NamedIndividual rdf:about="http://www.omac.org/#Schubert_claim_id23">
        <rdf:type rdf:resource="http://www.omac.org/#Claim"/>
        <isAbout rdf:resource="http://www.omac.org/#similarity_bet_De_Fevin_Missa_and_De_Pres_Ave_Maria"/>
        <madeBy rdf:resource="http://www.omac.org/#Peter_Schubert"/>
    </owl:NamedIndividual>
    


    <!-- http://www.omac.org/#similarity_bet_De_Fevin_Missa_and_De_Pres_Ave_Maria -->

    <owl:NamedIndividual rdf:about="http://www.omac.org/#similarity_bet_De_Fevin_Missa_and_De_Pres_Ave_Maria">
        <rdf:type rdf:resource="http://www.omac.org/#NonMechanicalTransformation"/>
        <hasDerivative rdf:resource="http://www.omac.org/#De_Fevin_Missa_Ave_Maria"/>
        <hasModel rdf:resource="http://www.omac.org/#De_Pres_Ave_Maria"/>
        <amplified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</amplified>
        <embellished rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</embellished>
        <newCombination rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</newCombination>
        <newCounterSubject rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</newCounterSubject>
        <oldCounterSubjectShifted rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</oldCounterSubjectShifted>
        <oldCounterSubjectTransposed rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</oldCounterSubjectTransposed>
        <reduced rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</reduced>
        <truncated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</truncated>
    </owl:NamedIndividual>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // General axioms
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.omac.org/#Allusion"/>
            <rdf:Description rdf:about="http://www.omac.org/#Arrangement"/>
            <rdf:Description rdf:about="http://www.omac.org/#Collage"/>
            <rdf:Description rdf:about="http://www.omac.org/#Contrafact"/>
            <rdf:Description rdf:about="http://www.omac.org/#Homage"/>
            <rdf:Description rdf:about="http://www.omac.org/#Imitation"/>
            <rdf:Description rdf:about="http://www.omac.org/#Omission"/>
            <rdf:Description rdf:about="http://www.omac.org/#Parody"/>
            <rdf:Description rdf:about="http://www.omac.org/#Plagiat"/>
            <rdf:Description rdf:about="http://www.omac.org/#Quotation"/>
            <rdf:Description rdf:about="http://www.omac.org/#Rendition"/>
            <rdf:Description rdf:about="http://www.omac.org/#Transcription"/>
            <rdf:Description rdf:about="http://www.omac.org/#Transformation"/>
        </owl:members>
    </rdf:Description>
    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.omac.org/#Claim"/>
            <rdf:Description rdf:about="http://www.omac.org/#Expression"/>
            <rdf:Description rdf:about="http://www.omac.org/#Person"/>
            <rdf:Description rdf:about="http://www.omac.org/#SimilarityRelationship"/>
        </owl:members>
    </rdf:Description>
    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.omac.org/#Claim"/>
            <rdf:Description rdf:about="http://www.omac.org/#Expression"/>
            <rdf:Description rdf:about="http://www.omac.org/#Person"/>
            <rdf:Description rdf:about="http://www.omac.org/#SimilarityRelationship"/>
            <rdf:Description rdf:about="http://www.omac.org/#Work"/>
        </owl:members>
    </rdf:Description>
    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.omac.org/#Elaboration"/>
            <rdf:Description rdf:about="http://www.omac.org/#MechanicalTransformation"/>
            <rdf:Description rdf:about="http://www.omac.org/#NewCombination"/>
            <rdf:Description rdf:about="http://www.omac.org/#NonMechanicalTransformation"/>
            <rdf:Description rdf:about="http://www.omac.org/#Prolongation"/>
            <rdf:Description rdf:about="http://www.omac.org/#Simplification"/>
            <rdf:Description rdf:about="http://www.omac.org/#Truncation"/>
        </owl:members>
    </rdf:Description>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Rules
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <rdf:Description rdf:about="urn:swrl#x">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="urn:swrl#z">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="urn:swrl#y">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
